{
  "name": "weblegko-sage",
  "private": true,
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "type": "module",
  "bin": {
    "wl": "./cli/index.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "cli": "node cli/index.js",
    "translate": "npm run translate:pot && npm run translate:update",
    "translate:pot": "wp i18n make-pot . ./resources/lang/sage.pot --include=\"theme.json,patterns,app,resources\"",
    "translate:update": "for file in ./resources/lang/*.po; do wp i18n update-po ./resources/lang/sage.pot $file; done",
    "translate:compile": "npm run translate:mo && npm run translate:js",
    "translate:js": "wp i18n make-json ./resources/lang --pretty-print",
    "translate:mo": "wp i18n make-mo ./resources/lang ./resources/lang",
    "fonts": "node --no-warnings .npm/fonts.js",
    "svg": "node .npm/svg.js",
    "webp": "node .npm/webp.js",
    "pots": "node .npm/pots.js"
  },
  "devDependencies": {
    "@roots/vite-plugin": "^2.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "chalk": "^5.6.2",
    "fonteditor-core": "^2.6.3",
    "fs-extra": "^11.3.6",
    "gettext-parser": "^9.1.1",
    "glob": "^13.0.6",
    "laravel-vite-plugin": "^3.0.0",
    "path": "^0.12.7",
    "sharp": "^0.35.3",
    "svg-sprite": "^2.0.4",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.0.0",
    "ttf2woff2": "^8.0.1",
    "url": "^0.11.4",
    "vite": "^8.0.0",
    "vite-plugin-svg-icons": "^2.0.1"
  },
  "dependencies": {
    "@alpinejs/collapse": "^3.15.12",
    "@alpinejs/focus": "^3.15.12",
    "@alpinejs/persist": "^3.15.12",
    "@floating-ui/dom": "^1.7.6",
    "alpinejs": "^3.15.12",
    "commander": "^15.0.0",
    "crypto": "^1.0.1",
    "fast-glob": "^3.3.3",
    "imask": "^7.6.1",
    "inquirer": "^14.0.2",
    "lucide-static": "^1.17.0",
    "ora": "^9.4.0",
    "swiper": "^14.0.2",
    "vite-plugin-static-copy": "^4.1.1"
  }
}
